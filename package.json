{
  "name": "slab-github-runner",
  "description": "GitHub Action for automatic AWS EC2 instance provisioning as a GitHub Actions self-hosted runner.",
  "author": "Zama",
  "license": "MIT",
  "version": "1.0.0",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zama-ai/slab-github-runner.git"
  },
  "bugs": {
    "url": "https://github.com/zama-ai/slab-github-runner/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "jest --passWithNoTests",
    "format:write": "prettier --write **/*.js",
    "format:check": "prettier --check **/*.js",
    "format:codebase": "prettier --write **/*js **/*.yml **/*.yaml **/*.md",
    "lint": "npx eslint . -c ./.github/linters/eslint.config.mjs",
    "package": "ncc build src/index.js --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "jest --passWithNoTests",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "eslintConfig": {
    "extends": "./.github/linters/.eslintrc.yml"
  },
  "jest": {
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "moduleNameMapper": {
      "^@actions/core$": "<rootDir>/node_modules/@actions/core/lib/core.js",
      "^@actions/github$": "<rootDir>/node_modules/@actions/github/lib/github.js"
    }
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/eslint-parser": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@eslint/js": "^9.39",
    "@eslint/eslintrc": "^3.3.5",
    "@vercel/ncc": "^0.38.1",
    "babel-preset-jest": "^29.6.3",
    "eslint": "^9.39",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.1",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.1.1"
  }
}
